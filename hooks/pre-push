#!/usr/bin/env bash
# hooks/pre-push
#
# Git pre-push hook — blocks the push when formatting or unit tests fail.
# Runs the two fastest mandatory CI gates:
#   1. check_formatting.sh  — black + isort (blocking)
#   2. run_tests.sh         — pytest unit tests
#
# Install once per clone:
#   bash scripts/install_hooks.sh
#
# Exit code: 0 = gates pass (push proceeds), 1 = gate failed (push blocked).

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPTS="$REPO_ROOT/scripts"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-push: running formatting + tests"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

FAILED=0

if ! bash "$SCRIPTS/check_formatting.sh"; then
    echo "❌  Formatting check failed — push blocked."
    FAILED=1
fi

if ! bash "$SCRIPTS/run_tests.sh"; then
    echo "❌  Unit tests failed — push blocked."
    FAILED=1
fi

if [ "$FAILED" -eq 0 ]; then
    echo "✅  Formatting and tests passed — push allowed."
fi

exit "$FAILED"
